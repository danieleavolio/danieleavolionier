{
	"name": "danieleavolio",
	"version": "1.0.0",
	"private": false,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"prepare": "husky install",
		"new:post": "node scripts/new-content.mjs post",
		"new:project": "node scripts/new-content.mjs project"
	},
	"devDependencies": {
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.53.4",
		"@types/node": "^25.3.5",
		"@typescript-eslint/eslint-plugin": "^5.45.0",
		"@typescript-eslint/parser": "^5.45.0",
		"eslint": "^8.28.0",
		"eslint-config-prettier": "^8.5.0",
		"eslint-plugin-svelte": "^3.15.0",
		"husky": "^8.0.3",
		"lint-staged": "^13.2.3",
		"mdsvex": "^0.12.6",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.53.7",
		"svelte-check": "^4.4.4",
		"tslib": "^2.4.1",
		"typescript": "^5.9.3",
		"vite": "^6.4.1"
	},
	"type": "module",
	"dependencies": {
		"@fontsource/jetbrains-mono": "^5.0.8",
		"@fontsource/manrope": "^5.0.8",
		"@vercel/analytics": "^1.6.1",
		"danieleavolio": "file:",
		"flexsearch": "^0.7.43",
		"i": "^0.3.7",
		"lucide-svelte": "^0.577.0",
		"open-props": "^1.5.11",
		"rehype-slug": "^5.1.0",
		"remark-toc": "^8.0.1",
		"remark-unwrap-images": "^3.0.1",
		"shiki": "^0.14.3"
	},
	"lint-staged": {
		"src/**/*.{js,jsx,ts,tsx,svelte,json,css,scss,md}": [
			"prettier --write"
		]
	},
	"engines": {
		"node": ">=22"
	}
}
